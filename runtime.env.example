# Template for mcp-hybris-suite-env/<env>/runtime.env
# Copy this file, fill in real values, never commit the result.

# --- HAC connection (required) ---
HYBRIS_BASE_URL=https://localhost:9002
HYBRIS_USERNAME=admin
HYBRIS_PASSWORD=nimda

# Optional HAC path override. Default is `/hac`. Set to an empty value
# (or `/`) when HAC is mounted at the servlet-context root, e.g.:
#   HYBRIS_HAC_PATH=
# Trailing slashes are stripped; leading slash is added if missing.

# --- Server log directory ---
# Enables list_logs / read_log / tail_latest_log / search_logs / correlate_logs.
# HYBRIS_LOG_PATH=/path/to/hybris/log

# --- Azure Blob Storage log fetch ---
# Enables azure_list_logs / azure_download_log / azure_read_log.
# Two auth modes — configure one:
#
# Option A: SAS URL (container-scoped, needs read+list permissions)
# AZURE_BLOB_LOG_SAS_URL=https://<account>.blob.core.windows.net/<container>?sv=...&sig=...
#
# Option B: Shared Key (account-level)
# AZURE_BLOB_LOG_ACCOUNT_NAME=
# AZURE_BLOB_LOG_ACCOUNT_KEY=
# AZURE_BLOB_LOG_CONTAINER=
# AZURE_BLOB_LOG_ENDPOINT=https://<account>.blob.core.windows.net
#
# Cache directory. Defaults to $HYBRIS_LOG_PATH/.azure-cache when HYBRIS_LOG_PATH is set.
# AZURE_BLOB_LOG_CACHE_DIR=/path/to/local/azure-log-cache

# --- Storefront login presets ---
# Naming pattern: STOREFRONT_<NAME>_URL / _USERNAME / _PASSWORD
# STOREFRONT_<NAME>_URL=
# STOREFRONT_<NAME>_USERNAME=
# STOREFRONT_<NAME>_PASSWORD=
# Optional per-preset overrides:
# STOREFRONT_<NAME>_LOGIN_PATH=/login
# STOREFRONT_<NAME>_LOGIN_SUBMIT_PATH=/j_spring_security_check
# STOREFRONT_<NAME>_SECURE_CHECK_PATH=/my-account
