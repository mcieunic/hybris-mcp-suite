# =============================================================================
# Hybris MCP Suite — environment configuration
# Copy this file to .env and fill in your values.
# Each MCP server reads only the variables it needs.
# =============================================================================

# -----------------------------------------------------------------------------
# RUNTIME MCP — connection to a running Hybris instance (HAC/OCC)
# -----------------------------------------------------------------------------
HYBRIS_BASE_URL=https://localhost:9002
HYBRIS_USERNAME=admin
HYBRIS_PASSWORD=nimda

# Optional site/catalog defaults
# HYBRIS_BASE_SITE_ID=electronics
# HYBRIS_CATALOG_ID=electronicsProductCatalog
# HYBRIS_CATALOG_VERSION=Online
# HYBRIS_HAC_PATH=/hac

# Server log directory (enables list_logs/read_log/tail_latest_log/search_logs)
# HYBRIS_LOG_PATH=/path/to/hybris/log

# Storefront login presets (see packages/runtime/README.md for full pattern)
# STOREFRONT_<NAME>_URL=
# STOREFRONT_<NAME>_USERNAME=
# STOREFRONT_<NAME>_PASSWORD=

# -----------------------------------------------------------------------------
# SOLR MCP — connection to Hybris Solr
# -----------------------------------------------------------------------------
SOLR_URL=http://localhost:8983/solr/
# SOLR_USERNAME=
# SOLR_PASSWORD=

# -----------------------------------------------------------------------------
# KNOWLEDGE MCP — local Hybris knowledge base + live source tree
# -----------------------------------------------------------------------------
# Root of the KB (defaults to packages/knowledge/ — the data ships in-package).
# Override only if you keep index/ + extensions/ somewhere else.
# HYBRIS_KB_ROOT=/path/to/knowledge-base
# Live Hybris source tree (target for hybris_kb_search_code via ripgrep)
HYBRIS_BIN_PATH=/Users/magdalenadabrowska/Documents/work/sniezka/sniezka2211jdk21/core-customize/hybris/bin

# -----------------------------------------------------------------------------
# Node.js — disable SSL validation for self-signed dev certs
# -----------------------------------------------------------------------------
# NODE_TLS_REJECT_UNAUTHORIZED=0
