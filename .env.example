# =============================================================================
# Hybris MCP Suite — environment variable reference
# These variables are passed via the "env" block in your MCP client config
# (.mcp.json, etc.). This file serves as a reference — the servers do NOT
# read .env files automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# RUNTIME MCP — connection to a running Hybris instance (HAC)
# -----------------------------------------------------------------------------
HYBRIS_BASE_URL=https://localhost:9002
HYBRIS_USERNAME=admin
HYBRIS_PASSWORD=nimda

# Optional HAC path override
# HYBRIS_HAC_PATH=/hac

# Server log directory (enables list_logs/read_log/tail_latest_log/search_logs/correlate_logs)
# HYBRIS_LOG_PATH=/path/to/hybris/log

# Azure Blob Storage log fetch (enables azure_list_logs/azure_download_log/azure_read_log).
# Blobs are downloaded into a local cache preserving the blob path layout
# so read_log/search_logs/correlate_logs work transparently on cached files.
# Two auth modes — configure one:
#
# Option A: SAS URL (container-scoped, needs read+list permissions)
# AZURE_BLOB_LOG_SAS_URL=https://<account>.blob.core.windows.net/<container>?sv=...&sig=...
#
# Option B: Shared Key (account-level)
# AZURE_BLOB_LOG_ACCOUNT_NAME=
# AZURE_BLOB_LOG_ACCOUNT_KEY=
# AZURE_BLOB_LOG_CONTAINER=
# AZURE_BLOB_LOG_ENDPOINT=https://<account>.blob.core.windows.net  (optional, this is the default)
#
# Cache directory. Defaults to $HYBRIS_LOG_PATH/.azure-cache when HYBRIS_LOG_PATH is set.
# AZURE_BLOB_LOG_CACHE_DIR=/path/to/local/azure-log-cache

# Storefront login presets — naming pattern: STOREFRONT_<NAME>_URL / _USERNAME / _PASSWORD
# STOREFRONT_<NAME>_URL=
# STOREFRONT_<NAME>_USERNAME=
# STOREFRONT_<NAME>_PASSWORD=
# Optional per-preset overrides:
# STOREFRONT_<NAME>_LOGIN_PATH=/login
# STOREFRONT_<NAME>_LOGIN_SUBMIT_PATH=/j_spring_security_check
# STOREFRONT_<NAME>_SECURE_CHECK_PATH=/my-account

# -----------------------------------------------------------------------------
# SOLR MCP — connection to Hybris Solr
# -----------------------------------------------------------------------------
SOLR_URL=http://localhost:8983/solr/
# SOLR_USERNAME=
# SOLR_PASSWORD=

# -----------------------------------------------------------------------------
# Node.js — disable SSL validation for self-signed dev certs
# -----------------------------------------------------------------------------
# NODE_TLS_REJECT_UNAUTHORIZED=0
