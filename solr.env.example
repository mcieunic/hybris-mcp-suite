# Template for mcp-hybris-suite-env/<env>/solr.env
# Copy this file, fill in real values, never commit the result.

# --- Direct Solr HTTP (solr_list_cores, solr_query, ...) ---
# Hybris bundles Solr with SSL enabled (project.properties → solrserver.instances.*.ssl.enabled=true),
# so the local default is https. Self-signed certs are tolerated automatically.
SOLR_URL=https://localhost:8983/solr/
# SOLR_USERNAME=
# SOLR_PASSWORD=

# --- HAC-proxied Solr (solr_*_via_hac) ---
# Required only for the *_via_hac tools (e.g. CCV2, where Solr is internal and
# not reachable from this host). Same values as runtime.env — copy them over.
# HYBRIS_BASE_URL=https://localhost:9002
# HYBRIS_USERNAME=admin
# HYBRIS_PASSWORD=nimda

# Optional HAC path override. Default is `/hac`. Set to an empty value
# (or `/`) when HAC is mounted at the servlet-context root, e.g.:
#   HYBRIS_HAC_PATH=
# Trailing slashes are stripped; leading slash is added if missing.
