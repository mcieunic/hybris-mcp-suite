{
  "name": "@hybris-mcp/runtime",
  "version": "0.1.0",
  "description": "MCP server for runtime operations against a SAP Commerce Cloud (Hybris) instance: products, orders, FlexibleSearch, Groovy, ImpEx, CronJobs, caches, logs, storefront, CMS export.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hybris-mcp-runtime": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "hybris",
    "sap",
    "commerce-cloud"
  ],
  "license": "MIT",
  "dependencies": {
    "@hybris-mcp/shared": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}
